<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_category_elastic" model="ir.module.category">
            <field name="name">Elastic Integration</field>
            <field name="description">Permissions for the Elastic Integration (SFTP) module.</field>
            <field name="sequence">20</field>
        </record>

        <record id="group_elastic_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_elastic"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Can view Elastic configuration, run exports/imports, and manage staged orders.</field>
        </record>

        <record id="group_elastic_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_elastic"/>
            <field name="implied_ids" eval="[(4, ref('group_elastic_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
            <field name="comment">Full configuration of Elastic connections, pricelists, catalogs, and security.</field>
        </record>
    </data>
</odoo>
