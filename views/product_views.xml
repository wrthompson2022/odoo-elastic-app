<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Product Template Form - Add Elastic Tab -->
    <record id="view_product_template_elastic_form" model="ir.ui.view">
        <field name="name">product.template.elastic.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Elastic" name="elastic">
                    <group>
                        <group string="Sync Settings">
                            <field name="elastic_sync_enabled"/>
                            <field name="elastic_last_sync" readonly="1"/>
                            <field name="elastic_product_id"/>
                        </group>
                        <group string="Catalog Assignment">
                            <field name="elastic_catalog_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <group>
                        <field name="elastic_features" widget="text" placeholder="JSON or text representation of product features"/>
                    </group>
                    <group>
                        <field name="elastic_notes" widget="text" placeholder="Additional notes for Elastic integration"/>
                    </group>
                    <div class="mt-3">
                        <button name="action_sync_to_elastic" type="object" string="Sync to Elastic" class="btn-primary" invisible="not elastic_sync_enabled"/>
                    </div>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Product Variant Form - Add Elastic Fields -->
    <record id="view_product_product_elastic_form" model="ir.ui.view">
        <field name="name">product.product.elastic.form</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='group_general']" position="after">
                <group string="Elastic Integration" name="elastic_group">
                    <group>
                        <field name="elastic_sync_enabled"/>
                        <field name="elastic_last_sync" readonly="1"/>
                    </group>
                    <group>
                        <field name="elastic_variant_id"/>
                        <field name="elastic_sku"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
