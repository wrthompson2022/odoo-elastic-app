<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Product Template Form - Add Elastic Tab -->
    <record id="view_product_template_elastic_form" model="ir.ui.view">
        <field name="name">product.template.elastic.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Elastic" name="elastic">
                    <group>
                        <group string="Sync Settings">
                            <field name="elastic_sync_enabled"/>
                            <field name="elastic_product_id"/>
                        </group>
                        <group string="Product Export Defaults">
                            <field name="elastic_product_permission_group"/>
                            <field name="elastic_available_date"/>
                        </group>
                    </group>
                    <group>
                        <group string="Shopify">
                            <field name="shopify_product_id"/>
                            <field name="shopify_handle"/>
                        </group>
                    </group>
                    <group>
                        <group string="Catalog Assignment">
                            <field name="elastic_catalog_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Product Variant Form - Replace inherited Elastic Tab -->
    <record id="view_product_product_elastic_form" model="ir.ui.view">
        <field name="name">product.product.elastic.form</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='elastic']" position="replace">
                <page string="Elastic" name="elastic">
                    <group>
                        <group string="Sync Settings">
                            <field name="elastic_sync_enabled"/>
                            <field name="elastic_last_sync" readonly="1"/>
                        </group>
                        <group string="Item Identifiers">
                            <field name="elastic_item_number"/>
                            <field name="elastic_stock_item_key"/>
                            <field name="elastic_sku"/>
                        </group>
                    </group>
                    <group>
                        <group string="Product Export Defaults">
                            <field name="elastic_product_permission_group"/>
                            <field name="elastic_available_date"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
