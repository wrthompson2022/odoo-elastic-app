<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Elastic Colors -->
    <record id="view_elastic_color_list" model="ir.ui.view">
        <field name="name">elastic.color.list</field>
        <field name="model">elastic.color</field>
        <field name="arch" type="xml">
            <list string="Elastic Colors">
                <field name="sort_order"/>
                <field name="code"/>
                <field name="name"/>
                <field name="color_group"/>
                <field name="hex_color"/>
                <field name="odoo_attribute_value_id"/>
                <field name="odoo_attribute_value_ids" widget="many2many_tags"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_elastic_color_form" model="ir.ui.view">
        <field name="name">elastic.color.form</field>
        <field name="model">elastic.color</field>
        <field name="arch" type="xml">
            <form string="Elastic Color">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="color_group"/>
                            <field name="sort_order"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="hex_color"/>
                            <field name="odoo_attribute_value_id"/>
                            <field name="odoo_attribute_value_ids" widget="many2many_tags"/>
                            <field name="external_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_elastic_color" model="ir.actions.act_window">
        <field name="name">Colors</field>
        <field name="res_model">elastic.color</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Elastic Size Scales -->
    <record id="view_elastic_size_scale_list" model="ir.ui.view">
        <field name="name">elastic.size.scale.list</field>
        <field name="model">elastic.size.scale</field>
        <field name="arch" type="xml">
            <list string="Elastic Size Scales">
                <field name="code"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_elastic_size_scale_form" model="ir.ui.view">
        <field name="name">elastic.size.scale.form</field>
        <field name="model">elastic.size.scale</field>
        <field name="arch" type="xml">
            <form string="Elastic Size Scale">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <field name="code"/>
                        <field name="active"/>
                    </group>
                    <field name="size_value_ids">
                        <list editable="bottom">
                            <field name="sort_order"/>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="alternate_size"/>
                            <field name="odoo_attribute_value_id"/>
                            <field name="active"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_elastic_size_scale" model="ir.actions.act_window">
        <field name="name">Size Scales</field>
        <field name="res_model">elastic.size.scale</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Elastic Size Values -->
    <record id="view_elastic_size_value_list" model="ir.ui.view">
        <field name="name">elastic.size.value.list</field>
        <field name="model">elastic.size.value</field>
        <field name="arch" type="xml">
            <list string="Elastic Size Values">
                <field name="scale_id"/>
                <field name="sort_order"/>
                <field name="code"/>
                <field name="name"/>
                <field name="alternate_size"/>
                <field name="odoo_attribute_value_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_elastic_size_value_form" model="ir.ui.view">
        <field name="name">elastic.size.value.form</field>
        <field name="model">elastic.size.value</field>
        <field name="arch" type="xml">
            <form string="Elastic Size Value">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="scale_id"/>
                            <field name="code"/>
                            <field name="sort_order"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="alternate_size"/>
                            <field name="odoo_attribute_value_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_elastic_size_value" model="ir.actions.act_window">
        <field name="name">Size Values</field>
        <field name="res_model">elastic.size.value</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Elastic Features -->
    <record id="view_elastic_feature_list" model="ir.ui.view">
        <field name="name">elastic.feature.list</field>
        <field name="model">elastic.feature</field>
        <field name="arch" type="xml">
            <list string="Elastic Features">
                <field name="display_order"/>
                <field name="code"/>
                <field name="name"/>
                <field name="feature_type"/>
                <field name="filterable"/>
                <field name="searchable"/>
                <field name="odoo_attribute_id"/>
                <field name="export_to_elastic"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_elastic_feature_form" model="ir.ui.view">
        <field name="name">elastic.feature.form</field>
        <field name="model">elastic.feature</field>
        <field name="arch" type="xml">
            <form string="Elastic Feature">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="feature_type"/>
                            <field name="display_order"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="odoo_attribute_id"/>
                            <field name="export_to_elastic"/>
                            <field name="filterable"/>
                            <field name="searchable"/>
                        </group>
                    </group>
                    <field name="value_ids">
                        <list editable="bottom">
                            <field name="display_order"/>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="odoo_attribute_value_id"/>
                            <field name="external_id"/>
                            <field name="active"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_elastic_feature" model="ir.actions.act_window">
        <field name="name">Features</field>
        <field name="res_model">elastic.feature</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Elastic Feature Values -->
    <record id="view_elastic_feature_value_list" model="ir.ui.view">
        <field name="name">elastic.feature.value.list</field>
        <field name="model">elastic.feature.value</field>
        <field name="arch" type="xml">
            <list string="Elastic Feature Values">
                <field name="feature_id"/>
                <field name="display_order"/>
                <field name="code"/>
                <field name="name"/>
                <field name="odoo_attribute_value_id"/>
                <field name="external_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_elastic_feature_value_form" model="ir.ui.view">
        <field name="name">elastic.feature.value.form</field>
        <field name="model">elastic.feature.value</field>
        <field name="arch" type="xml">
            <form string="Elastic Feature Value">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="feature_id"/>
                            <field name="code"/>
                            <field name="display_order"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="odoo_attribute_value_id"/>
                            <field name="external_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_elastic_feature_value" model="ir.actions.act_window">
        <field name="name">Feature Values</field>
        <field name="res_model">elastic.feature.value</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Product Feature Assignments -->
    <record id="view_elastic_product_feature_assignment_list" model="ir.ui.view">
        <field name="name">elastic.product.feature.assignment.list</field>
        <field name="model">elastic.product.feature.assignment</field>
        <field name="arch" type="xml">
            <list string="Product Feature Assignments">
                <field name="product_tmpl_id"/>
                <field name="product_id"/>
                <field name="feature_id"/>
                <field name="value_text"/>
                <field name="sequence"/>
                <field name="source"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_elastic_product_feature_assignment_form" model="ir.ui.view">
        <field name="name">elastic.product.feature.assignment.form</field>
        <field name="model">elastic.product.feature.assignment</field>
        <field name="arch" type="xml">
            <form string="Product Feature Assignment">
                <sheet>
                    <group>
                        <group>
                            <field name="product_tmpl_id"/>
                            <field name="product_id"/>
                            <field name="feature_id"/>
                            <field name="feature_value_id"/>
                            <field name="value_text"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="source"/>
                            <field name="source_key"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_elastic_product_feature_assignment" model="ir.actions.act_window">
        <field name="name">Product Feature Assignments</field>
        <field name="res_model">elastic.product.feature.assignment</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Elastic Product Tag Mappings -->
    <record id="view_elastic_product_tag_mapping_list" model="ir.ui.view">
        <field name="name">elastic.product.tag.mapping.list</field>
        <field name="model">elastic.product.tag.mapping</field>
        <field name="arch" type="xml">
            <list string="Elastic Product Tag Mappings">
                <field name="sequence"/>
                <field name="tag_name"/>
                <field name="source_model"/>
                <field name="field_id"/>
                <field name="split_mode"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_elastic_product_tag_mapping_form" model="ir.ui.view">
        <field name="name">elastic.product.tag.mapping.form</field>
        <field name="model">elastic.product.tag.mapping</field>
        <field name="arch" type="xml">
            <form string="Elastic Product Tag Mapping">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="tag_name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="sequence"/>
                            <field name="tag_name"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="source_model"/>
                            <field name="field_id"/>
                            <field name="split_mode"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_elastic_product_tag_mapping" model="ir.actions.act_window">
        <field name="name">Product Tag Mappings</field>
        <field name="res_model">elastic.product.tag.mapping</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Shopify Feature Import -->
    <record id="view_elastic_shopify_connection_list" model="ir.ui.view">
        <field name="name">elastic.shopify.connection.list</field>
        <field name="model">elastic.shopify.connection</field>
        <field name="arch" type="xml">
            <list string="Shopify Connections">
                <field name="name"/>
                <field name="shop_domain"/>
                <field name="api_version"/>
                <field name="match_strategy"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_elastic_shopify_connection_form" model="ir.ui.view">
        <field name="name">elastic.shopify.connection.form</field>
        <field name="model">elastic.shopify.connection</field>
        <field name="arch" type="xml">
            <form string="Shopify Connection">
                <header>
                    <button name="action_import_features" type="object" string="Import Features" class="oe_highlight"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="active"/>
                            <field name="shop_domain"/>
                            <field name="api_version"/>
                            <field name="match_strategy"/>
                        </group>
                        <group>
                            <field name="access_token" password="True"/>
                        </group>
                    </group>
                    <field name="mapping_ids">
                        <list editable="bottom">
                            <field name="sequence"/>
                            <field name="name"/>
                            <field name="feature_id"/>
                            <field name="source_type"/>
                            <field name="product_field_name"/>
                            <field name="metafield_namespace"/>
                            <field name="metafield_key"/>
                            <field name="parser"/>
                            <field name="active"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_elastic_shopify_connection" model="ir.actions.act_window">
        <field name="name">Shopify Feature Imports</field>
        <field name="res_model">elastic.shopify.connection</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
