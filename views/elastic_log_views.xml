<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Export Log Tree View -->
    <record id="view_elastic_export_log_tree" model="ir.ui.view">
        <field name="name">elastic.export.log.tree</field>
        <field name="model">elastic.export.log</field>
        <field name="arch" type="xml">
            <tree string="Export Logs" decoration-success="state=='success'" decoration-danger="state=='failed'" decoration-warning="state=='partial'">
                <field name="create_date"/>
                <field name="export_type"/>
                <field name="record_count"/>
                <field name="filename"/>
                <field name="state"/>
                <field name="create_uid"/>
            </tree>
        </field>
    </record>

    <!-- Export Log Form View -->
    <record id="view_elastic_export_log_form" model="ir.ui.view">
        <field name="name">elastic.export.log.form</field>
        <field name="model">elastic.export.log</field>
        <field name="arch" type="xml">
            <form string="Export Log">
                <sheet>
                    <group>
                        <group>
                            <field name="export_type"/>
                            <field name="model_name"/>
                            <field name="record_count"/>
                            <field name="filename"/>
                        </group>
                        <group>
                            <field name="state"/>
                            <field name="create_date"/>
                            <field name="create_uid"/>
                        </group>
                    </group>
                    <group>
                        <field name="message" widget="text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Export Log Search View -->
    <record id="view_elastic_export_log_search" model="ir.ui.view">
        <field name="name">elastic.export.log.search</field>
        <field name="model">elastic.export.log</field>
        <field name="arch" type="xml">
            <search string="Export Logs">
                <field name="export_type"/>
                <field name="filename"/>
                <filter string="Success" name="filter_success" domain="[('state', '=', 'success')]"/>
                <filter string="Failed" name="filter_failed" domain="[('state', '=', 'failed')]"/>
                <filter string="Partial" name="filter_partial" domain="[('state', '=', 'partial')]"/>
                <separator/>
                <filter string="Today" name="filter_today" domain="[('create_date', '&gt;=', datetime.datetime.now().replace(hour=0, minute=0, second=0))]"/>
                <filter string="Last 7 Days" name="filter_week" domain="[('create_date', '&gt;=', (context_today() - datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Export Type" name="group_export_type" context="{'group_by': 'export_type'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Export Log Action -->
    <record id="action_elastic_export_log" model="ir.actions.act_window">
        <field name="name">Export Logs</field>
        <field name="res_model">elastic.export.log</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_filter_week': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No export logs yet
            </p>
            <p>
                Export logs will appear here after you run exports to Elastic.
            </p>
        </field>
    </record>

    <!-- Import Log Tree View -->
    <record id="view_elastic_import_log_tree" model="ir.ui.view">
        <field name="name">elastic.import.log.tree</field>
        <field name="model">elastic.import.log</field>
        <field name="arch" type="xml">
            <tree string="Import Logs" decoration-success="state=='success'" decoration-danger="state=='failed'" decoration-warning="state=='partial'">
                <field name="create_date"/>
                <field name="import_type"/>
                <field name="file_count"/>
                <field name="record_count"/>
                <field name="error_count"/>
                <field name="state"/>
                <field name="create_uid"/>
            </tree>
        </field>
    </record>

    <!-- Import Log Form View -->
    <record id="view_elastic_import_log_form" model="ir.ui.view">
        <field name="name">elastic.import.log.form</field>
        <field name="model">elastic.import.log</field>
        <field name="arch" type="xml">
            <form string="Import Log">
                <sheet>
                    <group>
                        <group>
                            <field name="import_type"/>
                            <field name="file_count"/>
                            <field name="record_count"/>
                            <field name="error_count"/>
                        </group>
                        <group>
                            <field name="state"/>
                            <field name="create_date"/>
                            <field name="create_uid"/>
                        </group>
                    </group>
                    <group>
                        <field name="message" widget="text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Import Log Search View -->
    <record id="view_elastic_import_log_search" model="ir.ui.view">
        <field name="name">elastic.import.log.search</field>
        <field name="model">elastic.import.log</field>
        <field name="arch" type="xml">
            <search string="Import Logs">
                <field name="import_type"/>
                <filter string="Success" name="filter_success" domain="[('state', '=', 'success')]"/>
                <filter string="Failed" name="filter_failed" domain="[('state', '=', 'failed')]"/>
                <filter string="Partial" name="filter_partial" domain="[('state', '=', 'partial')]"/>
                <separator/>
                <filter string="Today" name="filter_today" domain="[('create_date', '&gt;=', datetime.datetime.now().replace(hour=0, minute=0, second=0))]"/>
                <filter string="Last 7 Days" name="filter_week" domain="[('create_date', '&gt;=', (context_today() - datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Import Type" name="group_import_type" context="{'group_by': 'import_type'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Import Log Action -->
    <record id="action_elastic_import_log" model="ir.actions.act_window">
        <field name="name">Import Logs</field>
        <field name="res_model">elastic.import.log</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_filter_week': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No import logs yet
            </p>
            <p>
                Import logs will appear here after you import data from Elastic.
            </p>
        </field>
    </record>
</odoo>
