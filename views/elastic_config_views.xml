<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Elastic Configuration Form View -->
    <record id="view_elastic_config_form" model="ir.ui.view">
        <field name="name">elastic.config.form</field>
        <field name="model">elastic.config</field>
        <field name="arch" type="xml">
            <form string="Elastic Configuration">
                <header>
                    <button name="action_test_connection" type="object" string="Test Active Connection" class="oe_highlight"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Configuration Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="connection_status" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- Environment & Connections -->
                        <page string="SFTP Connections" name="sftp_connections">
                            <group>
                                <group string="Active Environment">
                                    <field name="active_environment" widget="radio" options="{'horizontal': true}"/>
                                </group>
                                <group>
                                    <!-- Empty group for balanced two-column layout -->
                                </group>
                            </group>

                            <div class="alert alert-info" role="alert" style="margin-bottom: 20px;">
                                <strong>Environment Selection:</strong> Choose which SFTP environment to use for all operations.
                                Use <strong>Beta</strong> for testing and development, <strong>Production</strong> for live data.
                            </div>

                            <group>
                                <!-- Beta Connection -->
                                <group string="Beta / Sandbox Connection">
                                    <field name="beta_connection_id" options="{'no_create': True}"/>
                                    <div colspan="2">
                                        <button name="action_test_beta_connection" type="object" string="Test Beta" class="btn-secondary" icon="fa-plug" invisible="not beta_connection_id"/>
                                        <button name="action_create_beta_connection" type="object" string="Create Beta Connection" class="btn-link" icon="fa-plus" invisible="beta_connection_id"/>
                                    </div>
                                </group>

                                <!-- Production Connection -->
                                <group string="Production Connection">
                                    <field name="production_connection_id" options="{'no_create': True}"/>
                                    <div colspan="2">
                                        <button name="action_test_production_connection" type="object" string="Test Production" class="btn-secondary" icon="fa-plug" invisible="not production_connection_id"/>
                                        <button name="action_create_production_connection" type="object" string="Create Production Connection" class="btn-link" icon="fa-plus" invisible="production_connection_id"/>
                                    </div>
                                </group>
                            </group>

                            <separator string="Connection Management"/>
                            <div>
                                <button name="action_open_connections" type="object" string="Manage All Connections" class="btn-primary" icon="fa-cogs"/>
                            </div>
                        </page>

                        <!-- Export Settings -->
                        <page string="Export Settings" name="export_settings">
                            <group>
                                <group string="File Format">
                                    <field name="export_delimiter"/>
                                    <field name="export_encoding"/>
                                    <field name="export_include_header"/>
                                </group>
                                <group string="Date/Time Formatting">
                                    <field name="date_format"/>
                                    <field name="datetime_format"/>
                                </group>
                            </group>
                            <separator string="Enabled Exports"/>
                            <group>
                                <group>
                                    <field name="enable_product_export"/>
                                    <field name="enable_catalog_export"/>
                                    <field name="enable_catalog_mapping_export"/>
                                    <field name="enable_feature_export"/>
                                    <field name="enable_customer_export"/>
                                </group>
                                <group>
                                    <field name="enable_location_export"/>
                                    <field name="enable_rep_export"/>
                                    <field name="enable_rep_mapping_export"/>
                                    <field name="enable_inventory_export"/>
                                    <field name="enable_price_export"/>
                                </group>
                            </group>
                            <separator string="Manual Export Actions"/>
                            <div class="alert alert-info" role="alert" style="margin-bottom: 15px;">
                                <strong>Manual Exports:</strong> Click buttons below to run exports immediately.
                                For automated scheduled exports, configure cron jobs.
                            </div>
                            <div style="margin-bottom: 10px;">
                                <button name="action_export_all" type="object" string="Export All Enabled" class="btn-primary me-2" icon="fa-upload"/>
                            </div>
                            <group>
                                <group string="Customer Exports">
                                    <div>
                                        <button name="action_export_customers" type="object" string="Export Customers" class="btn-secondary me-1" icon="fa-users"/>
                                        <button name="action_export_customer_custom_fields" type="object" string="Export Custom Fields" class="btn-secondary" icon="fa-tags"/>
                                    </div>
                                </group>
                                <group string="Product Exports">
                                    <div>
                                        <button name="action_export_products" type="object" string="Export Products" class="btn-secondary me-1" icon="fa-cube"/>
                                        <button name="action_export_prices" type="object" string="Export Prices" class="btn-secondary me-1" icon="fa-usd"/>
                                        <button name="action_export_inventory" type="object" string="Export Inventory" class="btn-secondary" icon="fa-cubes"/>
                                    </div>
                                </group>
                            </group>
                            <group>
                                <group string="Catalog Exports">
                                    <div>
                                        <button name="action_export_catalogs" type="object" string="Export Catalogs" class="btn-secondary me-1" icon="fa-book"/>
                                        <button name="action_export_catalog_mappings" type="object" string="Export Mappings" class="btn-secondary" icon="fa-link"/>
                                    </div>
                                </group>
                                <group string="Sales Rep Exports">
                                    <div>
                                        <button name="action_export_reps" type="object" string="Export Reps" class="btn-secondary me-1" icon="fa-user-tie"/>
                                        <button name="action_export_rep_mappings" type="object" string="Export Rep Mappings" class="btn-secondary" icon="fa-handshake-o"/>
                                    </div>
                                </group>
                            </group>
                            <separator string="Export Filters"/>
                            <group>
                                <group>
                                    <field name="export_only_synced_products"/>
                                    <field name="export_only_synced_customers"/>
                                </group>
                                <group>
                                    <!-- Empty group for balanced two-column layout -->
                                </group>
                            </group>
                        </page>

                        <!-- Import Settings -->
                        <page string="Import Settings" name="import_settings">
                            <group>
                                <group string="Order Import">
                                    <field name="enable_order_import"/>
                                    <field name="order_import_auto_confirm"/>
                                    <field name="order_import_archive_processed"/>
                                    <field name="order_import_file_pattern"/>
                                    <field name="order_import_interval_hours"/>
                                </group>
                                <group string="Product Matching">
                                    <field name="order_stock_item_key_field"/>
                                </group>
                            </group>
                            <separator string="Manual Import Actions"/>
                            <div class="alert alert-info" role="alert" style="margin-bottom: 15px;">
                                <strong>Manual Import:</strong> Click "Import Orders Now" to poll SFTP immediately.
                                Failed rows are staged for review under <strong>Orders &gt; Staged Orders</strong>.
                            </div>
                            <div style="margin-bottom: 10px;">
                                <button name="action_import_orders" type="object"
                                        string="Import Orders Now" class="btn-primary me-2"
                                        icon="fa-download" invisible="not enable_order_import"/>
                                <button name="action_view_staged_orders" type="object"
                                        string="View Staged Orders" class="btn-secondary"
                                        icon="fa-list"/>
                            </div>
                        </page>

                        <!-- Business Logic -->
                        <page string="Business Logic" name="business_logic">
                            <group>
                                <group string="Customer Settings">
                                    <field name="use_legacy_account_number"/>
                                </group>
                                <group>
                                    <!-- Empty group for balanced two-column layout -->
                                </group>
                            </group>
                            <div class="alert alert-info" role="alert" style="margin-top: 10px;">
                                <strong>Legacy Account Number:</strong> When enabled, the system will use the "Legacy Account Number" field on customers for the SoldToID in exports before falling back to the Odoo Contact ID.
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Elastic Configuration Tree View -->
    <record id="view_elastic_config_tree" model="ir.ui.view">
        <field name="name">elastic.config.tree</field>
        <field name="model">elastic.config</field>
        <field name="arch" type="xml">
            <list string="Elastic Configurations">
                <field name="name"/>
                <field name="active"/>
                <field name="active_environment" widget="badge" decoration-info="active_environment == 'beta'" decoration-success="active_environment == 'production'"/>
                <field name="connection_status"/>
            </list>
        </field>
    </record>

    <!-- Elastic Configuration Action -->
    <record id="action_elastic_config" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">elastic.config</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configure Elastic Integration Settings
            </p>
            <p>
                Set up your SFTP connections for Beta and Production environments,
                configure export/import settings, and business logic preferences.
            </p>
        </field>
    </record>
</odoo>
